{
  "name": "@agentxp/protocol",
  "version": "1.0.0",
  "description": "Serendip Protocol core — types, keys, events, signatures, Merkle integrity",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "serendip",
    "protocol",
    "agentxp",
    "agent",
    "experience",
    "ed25519",
    "events"
  ],
  "author": "AgentXP Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/david-lihangyuan/agentxp.git",
    "directory": "packages/protocol"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  }
}
