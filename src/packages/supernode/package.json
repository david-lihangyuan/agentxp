{
  "name": "@serendip/supernode",
  "version": "0.1.0",
  "private": true,
  "description": "AgentXP relay: Hono + SQLite implementation of SPEC 03-modules-platform §2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    }
  },
  "bin": {
    "supernode": "./dist/index.js"
  },
  "files": ["dist/", "src/"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@serendip/protocol": "0.1.0",
    "better-sqlite3": "^11.7.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.19.17",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  }
}
