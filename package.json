{
  "name": "agentxp-monorepo",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david-lihangyuan/agentxp.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:hermes": "bash -c 'cd packages/skill-hermes && uv run pytest'",
    "lint:no-legacy": "bash scripts/check-no-legacy-imports.sh",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run format:check && npm run lint:no-legacy && npm run typecheck && npm test",
    "smoke": "npm run build && bash scripts/mvp-done-smoke.sh",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@noble/curves": "^1.8.0"
  }
}
